{
  "name": "claude-plugins",
  "version": "0.12.6",
  "type": "module",
  "description": "A collection of Claude Code plugins",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist/",
    "build:web-skills": "node scripts/build-web-skills/index.js",
    "test": "node test/run-tests.js",
    "coverage": "node --experimental-test-coverage --test test/**/*.test.js",
    "release": "release-it",
    "release:dry-run": "release-it --dry-run"
  },
  "devDependencies": {
    "@release-it/bumper": "7.0.5",
    "knip": "^5.85.0",
    "release-it": "19.2.4"
  },
  "knip": {
    "entry": [
      "plugins/dev-workflow/skills/view-cost-metrics/scripts/cost-workflow.js",
      "plugins/dev-workflow/skills/commit-with-costs/scripts/commit-workflow.js"
    ],
    "ignoreDependencies": [
      "ccusage"
    ]
  }
}
