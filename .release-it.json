{
  "git": {
    "push": false,
    "tagName": "v${version}",
    "commitMessage": "Version ${version}"
  },
  "github": {
    "release": false
  },
  "npm": {
    "publish": false,
    "version": false
  },
  "plugins": {
    "@release-it/bumper": {
      "out": [
        {
          "file": "package.json",
          "path": "version"
        },
        {
          "file": ".claude-plugin/marketplace.json",
          "path": "metadata.version"
        },
        {
          "file": ".claude-plugin/marketplace.json",
          "path": "plugins.0.version"
        }
      ]
    }
  }
}
